---
import type { Lang } from '../../i18n/utils';
import { localizedPath } from '../../i18n/utils';
import { getHome } from '../../data/home';
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const home = getHome(lang);
---

<Section background="default" padding="lg">
  <Container>
    <div class="relative max-w-2xl mx-auto text-center animate-on-scroll">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-sage/[0.04] rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

      <div class="relative">
        <h2 class="font-heading text-3xl sm:text-4xl font-medium text-text">
          {home.contactCta.heading}
        </h2>
        <p class="mt-4 text-text-secondary leading-relaxed max-w-lg mx-auto">
          {home.contactCta.text}
        </p>
        <div class="mt-8">
          <Button href={localizedPath(lang, home.contactCta.cta.href)} variant="primary" size="lg">
            {home.contactCta.cta.label}
          </Button>
        </div>
      </div>
    </div>
  </Container>
</Section>
