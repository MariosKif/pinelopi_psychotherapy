---
import type { Lang } from '../../i18n/utils';
import { localizedPath } from '../../i18n/utils';
import { getHome } from '../../data/home';
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const home = getHome(lang);
---

<section class="relative overflow-hidden py-20 sm:py-28 md:py-36 lg:py-44 bg-background">
  <!-- Organic decorative blobs -->
  <div class="absolute top-16 -right-32 w-80 h-80 bg-sage/[0.06] rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
  <div class="absolute -bottom-24 -left-20 w-72 h-72 bg-clay/[0.06] rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-sage-light/20 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

  <Container class="relative">
    <div class="max-w-2xl mx-auto text-center">
      <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl lg:text-[4.25rem] font-medium leading-[1.1] text-text tracking-tight animate-fade-up">
        {home.hero.headline}
      </h1>

      <p class="mt-6 sm:mt-8 text-base sm:text-lg text-text-secondary leading-relaxed max-w-xl mx-auto animate-fade-up" style="animation-delay: 0.1s;">
        {home.hero.subheadline}
      </p>

      <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4 animate-fade-up" style="animation-delay: 0.2s;">
        <Button href={localizedPath(lang, home.hero.cta.primary.href)} variant="primary" size="lg">
          {home.hero.cta.primary.label}
        </Button>
        <Button href={localizedPath(lang, home.hero.cta.secondary.href)} variant="secondary" size="lg">
          {home.hero.cta.secondary.label}
        </Button>
      </div>
    </div>
  </Container>

  <!-- Subtle scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 animate-fade-in hidden sm:block" style="animation-delay: 0.8s;" aria-hidden="true">
    <div class="w-5 h-8 border border-border-dark/50 rounded-full flex justify-center pt-1.5">
      <div class="w-1 h-2 bg-text-muted/40 rounded-full animate-bounce"></div>
    </div>
  </div>
</section>
