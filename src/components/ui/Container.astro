---
interface Props {
  class?: string;
  as?: 'div' | 'section' | 'article' | 'main';
  narrow?: boolean;
}

const { class: className = '', as: Tag = 'div', narrow = false } = Astro.props;
const width = narrow ? 'max-w-3xl' : 'max-w-6xl';
---

<Tag class:list={[width, 'mx-auto px-5 sm:px-6 lg:px-8', className]}>
  <slot />
</Tag>
