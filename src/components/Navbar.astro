---
import type { Lang } from '../i18n/utils';
import { localizedPath } from '../i18n/utils';
import { getSite } from '../data/site';
import Container from './ui/Container.astro';
import LanguageToggle from './LanguageToggle.astro';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const site = getSite(lang);
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-background/90 backdrop-blur-md border-b border-border/40 transition-all duration-300"
  id="site-header"
>
  <Container>
    <nav class="flex items-center justify-between h-16 sm:h-18" aria-label="Main navigation">
      <!-- Logo -->
      <a href={localizedPath(lang, '/')} class="flex items-center gap-2 group" aria-label={`${site.name} — Home`}>
        <span class="w-8 h-8 rounded-full bg-sage/10 flex items-center justify-center">
          <span class="w-3 h-3 rounded-full bg-sage"></span>
        </span>
        <span class="font-heading text-lg sm:text-xl font-medium text-text tracking-tight">
          {site.name}
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        {site.nav.map((item) => (
          <a
            href={localizedPath(lang, item.href)}
            class="px-3 py-2 text-sm text-text-secondary hover:text-sage-dark transition-colors duration-200 rounded-[--radius-md] hover:bg-sage-light/30"
          >
            {item.label}
          </a>
        ))}
        <div class="ml-2 mr-2">
          <LanguageToggle lang={lang} currentPath={currentPath} />
        </div>
        <a
          href={localizedPath(lang, '/contact')}
          class="inline-flex items-center px-5 py-2 text-sm font-medium text-white bg-sage rounded-[--radius-md] hover:bg-sage-dark transition-all duration-200 shadow-soft hover:shadow-card"
        >
          {site.contactLabel}
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        type="button"
        class="lg:hidden flex items-center justify-center w-10 h-10 rounded-[--radius-md] hover:bg-sage-light/30 transition-colors"
        id="mobile-menu-btn"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Toggle navigation menu"
      >
        <svg id="menu-icon-open" class="w-5 h-5 text-text" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
        </svg>
        <svg id="menu-icon-close" class="w-5 h-5 text-text hidden" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" d="M6 6l12 12M6 18L18 6" />
        </svg>
      </button>
    </nav>
  </Container>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-border/40 bg-background/95 backdrop-blur-md"
    role="dialog"
    aria-label="Navigation menu"
  >
    <Container>
      <div class="py-4 flex flex-col gap-1">
        <div class="flex justify-center mb-3">
          <LanguageToggle lang={lang} currentPath={currentPath} />
        </div>
        {site.nav.map((item) => (
          <a
            href={localizedPath(lang, item.href)}
            class="px-3 py-2.5 text-base text-text-secondary hover:text-sage-dark hover:bg-sage-light/30 rounded-[--radius-md] transition-colors"
          >
            {item.label}
          </a>
        ))}
        <a
          href={localizedPath(lang, '/contact')}
          class="mt-2 flex items-center justify-center px-5 py-3 text-sm font-medium text-white bg-sage rounded-[--radius-md] hover:bg-sage-dark transition-all duration-200"
        >
          {site.contactLabel}
        </a>
      </div>
    </Container>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 sm:h-18"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', !isOpen);
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
    btn.setAttribute('aria-expanded', String(isOpen));
  });

  // Close on navigation
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
