---
import type { Lang } from '../i18n/utils';
import { localizedPath } from '../i18n/utils';
import { getSite, siteShared } from '../data/site';
import Container from './ui/Container.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const site = getSite(lang);
const shared = siteShared;
---

<footer class="bg-surface-alt border-t border-border/60 pt-16 pb-8">
  <Container>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12 mb-12">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={localizedPath(lang, '/')} class="flex items-center gap-2 mb-4">
          <span class="w-7 h-7 rounded-full bg-sage/10 flex items-center justify-center">
            <span class="w-2.5 h-2.5 rounded-full bg-sage"></span>
          </span>
          <span class="font-heading text-lg font-medium text-text">{site.name}</span>
        </a>
        <p class="text-sm text-text-secondary leading-relaxed max-w-xs">
          {site.tagline}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-medium text-text mb-4">{site.footer.navHeading}</h3>
        <ul class="space-y-2.5">
          {site.nav.map((item) => (
            <li>
              <a
                href={localizedPath(lang, item.href)}
                class="text-sm text-text-secondary hover:text-sage-dark transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))}
          <li>
            <a
              href={localizedPath(lang, '/contact')}
              class="text-sm text-text-secondary hover:text-sage-dark transition-colors"
            >
              {site.contactLabel}
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-sm font-medium text-text mb-4">{site.footer.contactHeading}</h3>
        <ul class="space-y-2.5 text-sm text-text-secondary">
          <li>
            <a href={`mailto:${shared.contact.email}`} class="hover:text-sage-dark transition-colors">
              {shared.contact.email}
            </a>
          </li>
          <li>
            <a href={`tel:${shared.contact.phone.replace(/\s/g, '')}`} class="hover:text-sage-dark transition-colors">
              {shared.contact.phone}
            </a>
          </li>
          <li class="leading-relaxed">
            {shared.contact.address.street}<br />
            {shared.contact.address.area}, {shared.contact.address.city}<br />
            {shared.contact.address.postalCode}
          </li>
        </ul>
      </div>

      <!-- Hours -->
      <div>
        <h3 class="text-sm font-medium text-text mb-4">{site.footer.hoursHeading}</h3>
        <ul class="space-y-2.5 text-sm text-text-secondary">
          {site.hours.map((h) => (
            <li>
              <span class="block text-text-secondary">{h.days}</span>
              <span class="text-text">{h.time}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-border/60 pt-8 space-y-4">
      <p class="text-xs text-text-muted leading-relaxed max-w-3xl">
        {site.footer.disclaimer}
      </p>
      <p class="text-xs text-text-muted leading-relaxed max-w-3xl">
        {site.footer.privacy}
      </p>
      <p class="text-xs text-text-muted">
        {site.footer.copyright}
      </p>
    </div>
  </Container>
</footer>
